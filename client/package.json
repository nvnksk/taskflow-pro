{
  "name": "taskflow-pro-client",
  "version": "1.0.0",
  "private": true,
  "description": "React frontend for TaskFlow Pro",
  "scripts": {
    "start": "webpack serve --mode development",
    "dev": "webpack serve --mode development --open",
    "build": "webpack --mode production",
    "test": "jest",
